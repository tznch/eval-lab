# Secrets stay here. Shareable run recipes use profiles/*.yaml + .env.profile
# (never put API keys in profiles).

# HuggingFace (optional; higher rate limits / gated datasets)
# Prefer HF_TOKEN (standard). HF_FULL_ACCESS is accepted as an alias.
HF_TOKEN=hf_your_token_here
# HF_FULL_ACCESS=

# Eval dataset — any id from `make datasets-list`
EVAL_DATASET=sciq

# --- Judge (OpenRouter; any OpenRouter model id) ---
JUDGE_PROVIDER=openrouter
JUDGE_MODEL=tencent/hy3:free
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=tencent/hy3:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small

# --- Target model (OpenAI-compatible local server) ---
# Point these at whatever you serve with llama-server / vLLM / etc.
TARGET_MODEL_BASE_URL=http://127.0.0.1:8080/v1
TARGET_MODEL_NAME=local-model

# Optional: per-model endpoints after HuggingFace import (prefix = uppercased id)
# MY_MODEL_BASE_URL=http://127.0.0.1:8081/v1
# MY_MODEL_MODEL_NAME=MyModel-Q4
# MY_MODEL_MODEL_PATH=data/models/my-model/weights.gguf

# Universal local server auto-start (dashboard Run eval / make lab)
# LLAMA_SERVER=$HOME/.unsloth/llama.cpp/llama-server
# TARGET_MODEL_PATH=data/models/my-model/model.gguf
# LLAMA_HF_MODEL=org/Model-GGUF:Q4_K_M
# LLAMA_ARGS=--reasoning off
