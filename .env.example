# Secrets stay here. Shareable run recipes use profiles/*.yaml + .env.profile (never put API keys in profiles).
zai_api_key=your_zai_api_key_here

# HuggingFace (optional; higher rate limits / gated datasets)
# Prefer HF_TOKEN (standard). HF_FULL_ACCESS is accepted as an alias.
HF_TOKEN=hf_your_token_here
# HF_FULL_ACCESS=

# Eval dataset — any id from `make datasets-list`
EVAL_DATASET=sciq

# --- Judge (LLM-as-judge for DeepEval / RAGAS) ---
# Provider: openrouter (default) | glm
JUDGE_PROVIDER=openrouter

# Optional: one model for the active provider (overrides OPENROUTER_MODEL / GLM_MODEL)
JUDGE_MODEL=tencent/hy3:free

# OpenRouter — default; free hy3 recommended for eval scoring
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=tencent/hy3:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_EMBEDDING_MODEL=openai/text-embedding-3-small

# GLM (Z.ai Coding Plan) — set JUDGE_PROVIDER=glm to switch
GLM_BASE_URL=https://api.z.ai/api/coding/paas/v4
GLM_MODEL=glm-5.2
GLM_THINKING=disabled

# --- Target model (local llama-server) ---
TARGET_MODEL_BASE_URL=http://127.0.0.1:8080/v1
TARGET_MODEL_NAME=gemma-4-26b-a4b

# --- Bonsai-27B Q1 (1-bit, port 8081) ---
BONSAI_BASE_URL=http://127.0.0.1:8081/v1
BONSAI_MODEL_NAME=bonsai-27b-q1

# --- Qwen3.6-27B IQ2_XXS comparable baseline (port 8082) ---
# Whitepaper conventional quant vs Bonsai; run sequentially (make stop-servers first)
QWEN_BASE_URL=http://127.0.0.1:8082/v1
QWEN_MODEL_NAME=qwen3.6-27b-iq2
